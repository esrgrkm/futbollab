# Sanity CMS — https://sanity.io/manage
# 1. sanity.io/manage → Yeni proje oluştur
# 2. Proje ID'yi buraya yapıştır
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id

# Dataset adı (genellikle "production")
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity API Token (sadece server-side için, isteğe bağlı)
# sanity.io/manage → API → Tokens → Add API token
SANITY_API_TOKEN=your-api-token
